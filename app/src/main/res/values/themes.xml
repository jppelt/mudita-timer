<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!--
        Framework Material theme (no AppCompat, no Play Services, pure AOSP).
        Every color is overridden to pure black or white.
    -->
    <style name="AppTheme" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">@color/white</item>
        <item name="android:colorPrimary">@color/black</item>
        <item name="android:colorPrimaryDark">@color/black</item>
        <item name="android:colorAccent">@color/black</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:navigationBarColor">@color/black</item>

        <!-- Activity open/close animations cause a full-panel refresh on E Ink. -->
        <item name="android:windowAnimationStyle">@style/NoWindowAnimation</item>

        <!-- Global button style prevents Material ripple/shadow on any Button. -->
        <item name="android:buttonStyle">@style/AppButton</item>
    </style>

    <style name="NoWindowAnimation" parent="android:Animation.Activity">
        <item name="android:activityOpenEnterAnimation">@null</item>
        <item name="android:activityOpenExitAnimation">@null</item>
        <item name="android:activityCloseEnterAnimation">@null</item>
        <item name="android:activityCloseExitAnimation">@null</item>
        <item name="android:taskOpenEnterAnimation">@null</item>
        <item name="android:taskOpenExitAnimation">@null</item>
        <item name="android:taskCloseEnterAnimation">@null</item>
        <item name="android:taskCloseExitAnimation">@null</item>
        <item name="android:taskToFrontEnterAnimation">@null</item>
        <item name="android:taskToFrontExitAnimation">@null</item>
    </style>

    <style name="AppButton" parent="android:Widget.Material.Button">
        <item name="android:stateListAnimator">@null</item>
        <item name="android:background">@drawable/btn_filled</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:elevation">0dp</item>
    </style>

</resources>
