<?xml version="1.0" encoding="utf-8"?>
<!--
    Plain vector launcher icon — no <adaptive-icon> wrapper, so the system
    applies no shape clipping, no shadow, and no elevation. The white
    background is drawn explicitly inside the vector itself.

    Viewport 108×108 matches the existing hourglass path coordinates.
    Intrinsic size 48dp is the standard Android launcher icon dimension.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="48dp"
    android:height="48dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Pure white background -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M0,0 H108 V108 H0 Z" />

    <!-- Black hourglass silhouette with solid end plates -->
    <path
        android:fillColor="#000000"
        android:pathData="M20,18 L88,18 L88,26 L57,52 L57,56 L88,82 L88,90 L20,90 L20,82 L51,56 L51,52 L20,26 Z" />

</vector>
