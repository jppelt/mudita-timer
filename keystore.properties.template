# Copy this file to keystore.properties and fill in your values.
# keystore.properties is gitignored — never commit it.
#
# Generate the keystore with:
#   keytool -genkey -v \
#     -keystore /absolute/path/to/mudita-timer.jks \
#     -keyalg RSA -keysize 2048 -validity 10000 \
#     -alias mudita-timer \
#     -dname "CN=Mudita Timer, O=Personal, C=US"

storeFile=/absolute/path/to/mudita-timer.jks
storePassword=STORE_PASSWORD
keyAlias=mudita-timer
keyPassword=KEY_PASSWORD
